{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "nayori/dashboard-example-plugin",
    "type": "library",
    "description": "Example Nayori Workspaces plugin demonstrating the shared CRUD system.",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Plugins\\ExamplePlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Plugins\\ExamplePlugin\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
